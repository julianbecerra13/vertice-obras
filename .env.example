# Plantilla de variables de entorno. Copie a .env.local y rellene.
# Genere valores nuevos con: node scripts/generar-credenciales.mjs

ADMIN_USER=admin
ADMIN_PASSWORD_HASH=pbkdf2$100000$<salt-en-base64>$<hash-en-base64>
JWT_SECRET=<cadena-aleatoria-larga>

# Opcional en local, OBLIGATORIA en produccion.
# En Vercel se crea sola al conectar Neon desde el Marketplace.
DATABASE_URL=postgresql://usuario:clave@host/basededatos?sslmode=require
